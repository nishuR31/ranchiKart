# ── MudraKart Web — Build-time Variables ─────────────────────────────────
# These are injected at Docker build time, NOT at runtime.
# Copy to .env for local dev.

# The URL of the API (no trailing slash)
VITE_API_URL=http://localhost:4000

# For production Docker build, override via docker-compose build args:
#   VITE_API_URL=https://api.mudrakart.in
