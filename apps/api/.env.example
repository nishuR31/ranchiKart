# ── MudraKart API — Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in your actual values.

# Database (NeonDB PostgreSQL or any Postgres connection string)
DATABASE_URL=postgresql://user:password@host.neon.tech/mudrakart?sslmode=require

# JWT secret — use a long random string (min 32 chars)
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars

# Razorpay (get from dashboard.razorpay.com)
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# SMTP (optional — for order confirmation emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@mudrakart.in
SMTP_PASS=your-app-password
SMTP_FROM="MudraKart <noreply@mudrakart.in>"

# CORS — comma-separated allowed origins
CORS_ORIGIN=https://mudrakart.in,https://www.mudrakart.in

# Server
PORT=4000
HOST=0.0.0.0
NODE_ENV=production
