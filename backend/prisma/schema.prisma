generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"

}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  USER
  MANAGER
  ADMIN
  SELLER
}

enum ProductKind {
  EATABLE
  STATIONERY
  ELECTRONIC
  CLOTHING
  SHOE
  BAG
  ACCESSORY
  JEWELLERY
  BEAUTY
  HEALTH
  SPORT
  HOME
  KITCHEN
  GARDEN
  PET
  BABY
  TOY
  STAMP
  BOARD
  OTHER
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  UPI
  CARD
  CRYPTO
  NET_BANKING
  COINS
}

enum PaymentProvider {
  RAZORPAY
}

enum PaymentStatus {
  CREATED
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
}

enum CouponType {
  PERCENT
  FIXED
}

model User {
  id               String         @id @default(cuid())
  email            String         @unique
  name             String?    
  passwordHash     String?
  role             Role           @default(USER)
  avatarUrl        String?
  gender           String?
  phone            String?
  isEmailVerified  Boolean        @default(false)
  coins            Int            @default(0)
  isBanned         Boolean        @default(false)
  banReason        String?
  
  lastLogin        DateTime       @default(now())
  refreshToken     String?
  totpSecret       String?
  isTotpEnabled    Boolean        @default(false)
  
  orders           Order[]
  reviews          Review[]
  wishlist         Wishlist[]
  savedAddresses   SavedAddress[]
  adminLogs        AdminLog[]
  passkeys         PasskeyCredential[]
  
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([email])
}

model PasskeyCredential {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentialID   String   @unique
  credentialPublicKey Bytes
  counter        BigInt
  transports     String[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
}



model Category {
  id          String      @id @default(cuid())
  slug        String      @unique
  name        String
  description String
  imageUrl    String
  kind        ProductKind
  parentId    String?
  parent      Category?   @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[]  @relation("CategoryTree")
  products    Product[]
  coupons     Coupon[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([slug])
  @@index([parentId])
}

model Product {
  id               String           @id @default(cuid())
  categoryId       String
  category         Category         @relation(fields: [categoryId], references: [id])
  slug             String           @unique
  name             String
  description      String
  kind             ProductKind
  imageUrl         String
  gallery          Json             @default("[]")
  basePrice        Int
  currency         String           @default("INR")
  stock            Int              @default(dbgenerated("(random() * 100)::int"))
  isActive         Boolean          @default(true)
  isFeatured       Boolean          @default(false)
  tags             Json             @default("[]")
  highlights       Json             @default("[]")
  specifications   Json             @default("{}")
  rating           Float            @default(dbgenerated("mod((random() * 10)::int, 5) + random()"))
  reviewCount      Int              @default(0)
  replacementDays  Int              @default(7)
  returnEligible   Boolean          @default(false)
  warrantyText     String           @default("Manufacturing defects covered as per seller policy.")
  dispatchDays     Int              @default(3)
  minWidthMm       Int?
  maxWidthMm       Int?
  minHeightMm      Int?
  maxHeightMm      Int?
  defaultWidthMm   Int?
  defaultHeightMm  Int?
  options          Json             @default("{}")
  variants         ProductVariant[]
  orderItems       OrderItem[]
  reviews          Review[]
  wishlistItems    Wishlist[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([slug])
  @@index([categoryId])
  @@index([isActive])
  @@index([isFeatured])
}

model ProductVariant {
  id         String      @id @default(cuid())
  productId  String
  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  name       String
  sku        String      @unique
  priceDelta Int         @default(0)
  attributes Json        @default("{}")
  stock      Int         @default(100)
  orderItems OrderItem[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([productId])
}

model Review {
  id             String   @id @default(cuid())

  productId      String
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  orderId        String?
  order          Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)

  rating         Int
  title          String?
  body           String

  isVerified     Boolean  @default(false)
  helpfulCount   Int      @default(0)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([productId, userId])
  @@index([productId])
  @@index([userId])
  @@index([orderId])
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
}

model Coupon {
  id             String     @id @default(cuid())
  code           String     @unique
  description    String?
  type           CouponType @default(PERCENT)
  value          Int        // percent (0-100) or fixed paisa amount
  minOrderAmount Int        @default(0)
  maxUses        Int?
  usedCount      Int        @default(0)
  isActive       Boolean    @default(true)
  expiresAt      DateTime?
  categoryId     String?    // if set, coupon only applies to this category
  category       Category?  @relation(fields: [categoryId], references: [id])
  orders         Order[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([code])
  @@index([categoryId])
}

model SavedAddress {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label     String   @default("Home")
  fullName  String
  phone     String
  line1     String
  line2     String?
  city      String
  state     String
  pincode   String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Order {
  id             String        @id @default(cuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id])
  status         OrderStatus   @default(PENDING_PAYMENT)
  paymentMethod  PaymentMethod
  subtotal       Int
  shippingFee    Int           @default(0)
  discountAmount Int           @default(0)
  total          Int
  address        Json
  trackingId     String?
  notes          String?
    reviews Review[]

  couponId       String?
  coupon         Coupon?       @relation(fields: [couponId], references: [id])
  items          OrderItem[]
  payments       Payment[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

 @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([couponId])
}

model OrderItem {
  id              String          @id @default(cuid())
  orderId         String
  order           Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId       String
  product         Product         @relation(fields: [productId], references: [id])
  variantId       String?
  variant         ProductVariant? @relation(fields: [variantId], references: [id])
  quantity        Int
  unitPrice       Int
  total           Int
  customWidthMm   Int?
  customHeightMm  Int?
  customText      String?
  customization   Json            @default("{}")
}

model Payment {
  id                String          @id @default(cuid())
  orderId           String
  order             Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  provider          PaymentProvider
  status            PaymentStatus   @default(CREATED)
  amount            Int
  currency          String          @default("INR")
  providerOrderId   String          @unique
  providerPaymentId String?
  providerSignature String?
  rawResponse       Json?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([orderId])
}

model AdminLog {
  id        String   @id @default(cuid())
  adminId   String
  admin     User     @relation(fields: [adminId], references: [id])
  action    String
  entity    String
  entityId  String?
  meta      Json?
  createdAt DateTime @default(now())

  @@index([adminId])
  @@index([entity])
}
