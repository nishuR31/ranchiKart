{
  "name": "@ranchiKart/api",
  "version": "2.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "bun run typecheck",
    "format": "bunx prettier --write .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "bun run src/index.ts",
    "start": "bun run src/index.ts",
    "run": "bun run dist/index.js",
    "build": "rm -rf dist/ && bunx tsc -p tsconfig.json",
    "db:gen": "bunx prisma generate",
    "db:push": "bunx prisma db push",
    "db": "bun run db:gen && bun run db:push",
    "db:migrate": "PRISMA_SCHEMA_ENGINE_LOG_LEVEL=trace RUST_LOG=trace prisma migrate dev --name init",
    "db:seed": "bun prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/compress": "^9.0.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.0.1",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^9.1.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/sensible": "^6.0.3",
    "@fastify/static": "^10.1.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^6.0.0",
    "@prisma/client": "^6.9.0",
    "@simplewebauthn/server": "^13.3.2",
    "@types/nodemailer": "^8.0.0",
    "argon2": "^0.43.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.5.0",
    "fast-jwt": "^6.2.4",
    "fastify": "^5.3.3",
    "fastify-plugin": "^6.0.0",
    "ioredis": "^5.6.1",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.11",
    "otplib": "^13.4.1",
    "qrcode": "^1.5.4",
    "razorpay": "^2.9.6",
    "status-map": "^1.0.7",
    "zod": "^3.25.56",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.0.3",
    "@types/qrcode": "^1.5.6",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.9.4",
    "prisma": "^6.9.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "prisma": {
    "seed": "bun prisma/seed.ts"
  }
}
